@client.command(aliases=["draw"])
async def withdraw(ctx, amount = 0):

    await open_account(ctx.author)
    amount = int(amount)

    if amount == 0:
        await ctx.send("Please enter the amount of money you want to withdraw")
        return
    
    bal = await update_bank(ctx.author)

    if amount > bal[1]:
        await ctx.send("You don't have enough money to withdraw that much")
        return
    if amount < 0:
        await ctx.send("The amount needs to be positive")
        return  

    await update_bank(ctx.author, amount)
    await update_bank(ctx.author, -1*amount, "bank")

    await ctx.send(f"you withdrew {amount} coins")      


